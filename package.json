{
  "name": "merge-mentor",
  "version": "1.11.0",
  "description": "Automated code review bot powered by AI CLI tools (Copilot, OpenCode, Cursor)",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && cross-env NODE_ENV=production node build.mjs",
    "build:dev": "tsc --noEmit && node build.mjs",
    "review": "node dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && biome check src && npm run test",
    "knip": "knip"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli",
    "pr-review",
    "code-quality",
    "static-analysis"
  ],
  "author": "archerax",
  "license": "UNLICENSED",
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "azure-devops-node-api": "^15.1.1",
    "commander": "^14.0.2",
    "diff": "^8.0.2",
    "dotenv": "^17.2.3",
    "openai": "^6.16.0",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^25.0.2",
    "@vitest/coverage-v8": "^4.0.16",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.2",
    "knip": "^5.81.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
