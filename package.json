{
  "name": "merge-mentor",
  "version": "2.10.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archerax/merge-mentor.git"
  },
  "description": "Automated code review bot powered by AI CLI tools (Copilot, OpenCode, Cursor)",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && cross-env NODE_ENV=production node build.mjs",
    "build:dev": "tsc --noEmit && node build.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"**/*.{md,yml}\" && biome check && knip",
    "lint:fix": "prettier --write \"**/*.{md,yml}\" && biome check --write && knip --fix",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:site": "typedoc --options typedoc.site.json",
    "docs:serve": "pnpm docs:site && node scripts/docs-serve.mjs",
    "prepare": "lefthook install"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli",
    "pr-review",
    "code-quality",
    "static-analysis"
  ],
  "author": "archerax",
  "license": "MIT",
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@github/copilot": "^1.0.71",
    "@github/copilot-sdk": "^1.0.7",
    "@octokit/rest": "^22.0.1",
    "@opencode-ai/sdk": "^1.18.3",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "isomorphic-git": "^1.38.7",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^25.9.5",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "lefthook": "^2.1.10",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^7.0.2",
    "vite": "8.1.5",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
