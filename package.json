{
  "name": "merge-mentor",
  "version": "1.0.0",
  "description": "Automated code review bot using GitHub Copilot CLI",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "review": "node dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && biome check src && npm run test"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli"
  ],
  "author": "archerax",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.0.2",
    "azure-devops-node-api": "^15.1.1",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@vitest/coverage-v8": "^4.0.16",
    "vitest": "^4.0.16"
  }
}
