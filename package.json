{
  "name": "merge-mentor",
  "version": "1.13.0",
  "description": "Automated code review bot powered by AI CLI tools (Copilot, OpenCode, Cursor)",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && cross-env NODE_ENV=production node build.mjs",
    "build:dev": "tsc --noEmit && node build.mjs",
    "check": "pnpm build && pnpm test && pnpm lint",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx prettier --write **/*.{md,yml} && biome check && knip",
    "lint:fix": "npx prettier --write **/*.{md,yml} && biome check --write && knip --fix"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli",
    "pr-review",
    "code-quality",
    "static-analysis"
  ],
  "author": "archerax",
  "license": "UNLICENSED",
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@github/copilot-sdk": "^0.1.25",
    "@octokit/rest": "^22.0.1",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "knip": "^5.88.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
