{
  "name": "merge-mentor",
  "version": "2.4.3",
  "description": "Automated code review bot powered by AI CLI tools (Copilot, OpenCode, Cursor)",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && cross-env NODE_ENV=production node build.mjs",
    "build:dev": "tsc --noEmit && node build.mjs",
    "check": "pnpm build && pnpm test && pnpm lint",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx prettier --check **/*.{md,yml} && biome check && knip",
    "lint:fix": "npx prettier --write **/*.{md,yml} && biome check --write && knip --fix",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:site": "typedoc --options typedoc.site.json",
    "docs:serve": "pnpm docs:site && node scripts/docs-serve.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli",
    "pr-review",
    "code-quality",
    "static-analysis"
  ],
  "author": "archerax",
  "license": "MIT",
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@github/copilot": "^1.0.63",
    "@github/copilot-sdk": "^1.0.2",
    "@octokit/rest": "^22.0.1",
    "@opencode-ai/sdk": "^1.17.9",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "isomorphic-git": "^1.38.5",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185"
  }
}
