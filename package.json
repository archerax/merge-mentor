{
  "name": "merge-mentor",
  "version": "1.31.0",
  "description": "Automated code review bot powered by AI CLI tools (Copilot, OpenCode, Cursor)",
  "main": "dist/cli.js",
  "bin": {
    "merge-mentor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && cross-env NODE_ENV=production node build.mjs",
    "build:dev": "tsc --noEmit && node build.mjs",
    "check": "pnpm build && pnpm test && pnpm lint",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx prettier **/*.{md,yml} && biome check && knip",
    "lint:fix": "npx prettier --write **/*.{md,yml} && biome check --write && knip --fix",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:site": "typedoc --options typedoc.site.json",
    "docs:serve": "pnpm docs:site && node scripts/docs-serve.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "code-review",
    "github",
    "azure-devops",
    "copilot",
    "pull-request",
    "automated-review",
    "cli",
    "pr-review",
    "code-quality",
    "static-analysis"
  ],
  "author": "archerax",
  "license": "PROPRIETARY",
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "@octokit/rest": "^22.0.1",
    "@opencode-ai/sdk": "^1.4.3",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "isomorphic-git": "^1.37.5",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1",
    "vite": "8.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "knip": "^6.6.0",
    "prettier": "^3.8.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
