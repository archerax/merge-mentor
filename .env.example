# Platform Selection (default)
DEFAULT_PLATFORM=github

# GitHub Configuration
GITHUB_TOKEN=<personal_access_token>
GITHUB_REPO_OWNER=<username_or_org>
GITHUB_REPO_NAME=<repository_name>

# Azure DevOps Configuration
AZURE_DEVOPS_TOKEN=<personal_access_token>
AZURE_DEVOPS_ORG=<organization_name>
AZURE_DEVOPS_PROJECT=<project_name>
AZURE_DEVOPS_REPO=<repository_name>

# Bot Configuration
BOT_COMMENT_IDENTIFIER=[MergeMentor]

# Copilot Configuration
COPILOT_GITHUB_TOKEN=<copilot_personal_access_token>
COPILOT_MODEL=gpt-4o

# Comment Filtering Configuration
MIN_COMMENT_CONFIDENCE=high  # Minimum confidence level (high, medium, low). Default: high
SKIP_PREEXISTING_ISSUES=true  # Skip issues that existed before the PR. Default: true
POST_RESOLUTION_COMMENTS=true  # Post explanation before resolving comments. Default: true

# Review Runs Configuration
REVIEW_RUNS=1  # Number of review runs (1-5). Higher values increase thoroughness but also time/cost. Default: 1
