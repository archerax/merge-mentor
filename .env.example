# ==============================================================================
# Merge Mentor - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your custom values.
# All environment variables are prefixed with 'MM_' to avoid conflicts.

# ------------------------------------------------------------------------------
# 1. Platform Selection
# ------------------------------------------------------------------------------
# The default hosting platform for your pull requests.
# Options: github, azure (Default: github)
MM_PLATFORM=github

# ------------------------------------------------------------------------------
# 2. GitHub Configuration
# ------------------------------------------------------------------------------
# Required when MM_PLATFORM=github or using a GitHub PR URL.
MM_GITHUB_TOKEN=<your_github_personal_access_token>
MM_GITHUB_REPO_OWNER=<username_or_organization>
MM_GITHUB_REPO_NAME=<repository_name>

# ------------------------------------------------------------------------------
# 3. Azure DevOps Configuration
# ------------------------------------------------------------------------------
# Required when MM_PLATFORM=azure or using an Azure DevOps PR URL.
MM_AZURE_TOKEN=<your_azure_devops_personal_access_token>
MM_AZURE_ORG=<organization_name>
MM_AZURE_PROJECT=<project_name>
MM_AZURE_REPO=<repository_name>

# ------------------------------------------------------------------------------
# 4. AI Provider Configuration
# ------------------------------------------------------------------------------
# The AI provider engine to use for performing code reviews.
# Options: copilot-sdk, opencode-sdk (Default: copilot-sdk)
MM_AI_PROVIDER=copilot-sdk

# ------------------------------------------------------------------------------
# 5. Copilot Configuration
# ------------------------------------------------------------------------------
# Required ONLY when using the 'copilot-sdk' provider.
MM_COPILOT_TOKEN=<your_copilot_github_token>

# ------------------------------------------------------------------------------
# 6. Unified AI Settings (Model, BYOK, Timeouts)
# ------------------------------------------------------------------------------
# Customize the model, timeouts, or custom OpenAI-compatible (BYOK) endpoints.
# These unified settings apply across all active AI providers.

# Model name/identifier for the active AI provider (Default: provider-specific)
# MM_AI_MODEL=claude-sonnet-4.6

# Global timeout in milliseconds for AI requests (e.g. 1 hour = 3600000)
# MM_AI_TIMEOUT=3600000

# Custom OpenAI-compatible API base URL for BYOK providers
# MM_AI_BASE_URL=https://api.openai.com/v1

# Custom API key for BYOK providers
# MM_AI_API_KEY=<your_custom_api_key>

# ------------------------------------------------------------------------------
# 7. Git Backend Configuration
# ------------------------------------------------------------------------------
# Git engine for cloning and fetching repository data.
# Options: cli (uses system git binary), isomorphic (js-based git) (Default: cli)
# MM_GIT_BACKEND=cli

# ------------------------------------------------------------------------------
# 8. Review & Profile Configuration
# ------------------------------------------------------------------------------
# Control the thoroughness, rules, and scopes of the pull request review.

# The type/focus profile of the review.
# Options: general, testing, security, performance, fast, custom (Default: general)
MM_REVIEW_TYPE=general

# Execution strategy for running the review passes.
# Options: deep, fast (Default: fast)
# MM_REVIEW_STRATEGY=fast

# Comma-separated additive review passes to run (Required when MM_REVIEW_TYPE=custom).
# Options: scan, security, logic, performance, monorepo, testing, database
# MM_REVIEW_PASSES=scan,logic,security

# ------------------------------------------------------------------------------
# 9. Streaming Output Display
# ------------------------------------------------------------------------------
# Configuration for real-time review progress streaming in interactive terminals.

# Show real-time streaming of AI responses in the CLI.
# Options: true, false (Default: true)
# MM_STREAMING_ENABLED=true

# Height (number of lines) for the active streaming terminal display.
# Options: 1-20 (Default: 9)
# MM_STREAMING_LINES=9

# ------------------------------------------------------------------------------
# 10. Temporary Directory & Logging
# ------------------------------------------------------------------------------
# Base path for cache, git operations, local diffs, and logs.
# MM_TEMP_PATH=./.mergementor

# Application logging level.
# Options: error, warn, info, debug, verbose (Default: info)
# LOG_LEVEL=info
