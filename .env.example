# Platform Selection (default)
MM_PLATFORM=github

# GitHub Configuration
MM_GITHUB_TOKEN=<personal_access_token>
MM_GITHUB_REPO_OWNER=<username_or_org>
MM_GITHUB_REPO_NAME=<repository_name>

# Azure DevOps Configuration
MM_AZURE_TOKEN=<personal_access_token>
MM_AZURE_ORG=<organization_name>
MM_AZURE_PROJECT=<project_name>
MM_AZURE_REPO=<repository_name>

# Bot Configuration
MM_COMMENT_IDENTIFIER=[MergeMentor]

# Temporary Directory Configuration
# MM_TEMP_PATH=./.mergementor  # Base path for temporary files (cache, diffs, logs, repos, etc.). Supports absolute and relative paths. Default: ./.mergementor

# AI Provider Configuration
MM_AI_PROVIDER=copilot  # Options: copilot, copilot-sdk, opencode, opencode-sdk. Default: copilot

# Copilot Configuration
MM_COPILOT_TOKEN=<copilot_personal_access_token>
MM_COPILOT_MODEL=claude-sonnet-4.6
# MM_COPILOT_TIMEOUT=3600000  # Optional timeout in milliseconds

# Copilot SDK Configuration
# MM_COPILOT_SDK_MODEL=claude-sonnet-4.6
# MM_COPILOT_SDK_TIMEOUT=3600000  # Optional timeout in milliseconds

# OpenCode Configuration
# MM_OPENCODE_MODEL=claude-sonnet-4.6
# MM_OPENCODE_TIMEOUT=3600000  # Optional timeout in milliseconds

# OpenCode SDK Configuration
# MM_OPENCODE_SDK_MODEL=claude-sonnet-4.6
# MM_OPENCODE_SDK_TIMEOUT=3600000  # Optional timeout in milliseconds


# Review Configuration
MM_SKIP_EXISTING_ISSUES=true  # Skip issues that existed before the PR. Default: true
MM_REVIEW_RUNS=1  # Number of review runs (1-5). Higher values increase thoroughness but also time/cost. Default: 1

# Review Type Configuration (Specialist Reviews)
# Options: general (default), testing, security, performance, fast
MM_REVIEW_TYPE=general  # General comprehensive review (2 AI calls)

# Example configurations for specialist reviews:
# MM_REVIEW_TYPE=fast         # Single-pass review (~50% cost reduction, same coverage as general)
# MM_REVIEW_TYPE=testing      # Focus on test coverage, quality, and naming conventions
# MM_REVIEW_TYPE=security     # Focus on vulnerabilities and security threats
# MM_REVIEW_TYPE=performance  # Focus on performance optimization opportunities

# Testing Review Examples:
# - Test coverage analysis (are new functions tested?)
# - Test naming conventions (C#: MethodName_Scenario_ExpectedBehavior, TypeScript: describe/it)
# - Assertion verification (do assertions match test behavior?)
# - Mock framework usage (proper mocking patterns for language)
