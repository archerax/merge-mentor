# Platform Selection (default)
MM_PLATFORM=github

# GitHub Configuration
MM_GITHUB_TOKEN=<personal_access_token>
MM_GITHUB_REPO_OWNER=<username_or_org>
MM_GITHUB_REPO_NAME=<repository_name>

# Azure DevOps Configuration
MM_AZURE_TOKEN=<personal_access_token>
MM_AZURE_ORG=<organization_name>
MM_AZURE_PROJECT=<project_name>
MM_AZURE_REPO=<repository_name>

# Bot Configuration
MM_COMMENT_IDENTIFIER=[MergeMentor]

# AI Provider Configuration
MM_AI_PROVIDER=copilot  # Options: copilot, opencode, cursor, openai. Default: copilot

# Copilot Configuration
MM_COPILOT_TOKEN=<copilot_personal_access_token>
MM_COPILOT_MODEL=gpt-4o
# MM_COPILOT_TIMEOUT=300000  # Optional timeout in milliseconds

# OpenCode Configuration
# MM_OPENCODE_MODEL=gpt-4o
# MM_OPENCODE_TIMEOUT=300000  # Optional timeout in milliseconds

# Cursor Configuration
# MM_CURSOR_MODEL=gpt-4o
# MM_CURSOR_TIMEOUT=300000  # Optional timeout in milliseconds

# OpenAI Configuration
# MM_OPENAI_API_KEY=<your_openai_api_key>
# MM_OPENAI_MODEL=gpt-4o
# MM_OPENAI_BASE_URL=https://api.openai.com/v1  # Optional, for Azure OpenAI or custom endpoints
# MM_OPENAI_TIMEOUT=300000  # Optional timeout in milliseconds
# MM_OPENAI_MAX_RETRIES=3  # Optional, default is 2

# Review Configuration
MM_SKIP_EXISTING_ISSUES=true  # Skip issues that existed before the PR. Default: true
MM_REVIEW_RUNS=1  # Number of review runs (1-5). Higher values increase thoroughness but also time/cost. Default: 1
