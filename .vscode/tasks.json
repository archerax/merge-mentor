{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build:dev"],
      "problemMatcher": ["$tsc"],
      "isBackground": false,
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "problemMatcher": ["$tsc"],
      "isBackground": false,
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "npm",
      "args": ["run", "typecheck"],
      "problemMatcher": ["$tsc"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test"],
      "isBackground": false,
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
